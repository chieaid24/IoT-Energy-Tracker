{
  "uid": "kafka-event-pipeline",
  "title": "Kafka Event Pipeline",
  "tags": ["iot", "kafka"],
  "timezone": "browser",
  "refresh": "30s",
  "time": { "from": "now-1h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "title": "Kafka Template Send Rate",
      "description": "Rate of messages sent via Spring KafkaTemplate (ingestion-service produces to energy-usage, usage-service produces to energy-alerts)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "targets": [{ "expr": "rate(spring_kafka_template_seconds_count[5m])", "legendFormat": "{{job}}", "refId": "A" }],
      "fieldConfig": { "defaults": { "unit": "ops" } },
      "datasource": { "type": "prometheus", "uid": "prometheus" }
    },
    {
      "id": 2,
      "title": "Consumer Lag",
      "description": "Kafka consumer lag — how far behind the consumer is from the latest offset",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "targets": [{ "expr": "kafka_consumer_fetch_manager_records_lag{job=\"usage-service\"}", "legendFormat": "{{topic}} {{partition}}", "refId": "A" }],
      "fieldConfig": { "defaults": { "unit": "short" } },
      "datasource": { "type": "prometheus", "uid": "prometheus" }
    },
    {
      "id": 3,
      "title": "Messages Consumed Rate (usage-service)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "targets": [{ "expr": "rate(kafka_consumer_fetch_manager_records_consumed_total{job=\"usage-service\"}[5m])", "legendFormat": "{{topic}}", "refId": "A" }],
      "fieldConfig": { "defaults": { "unit": "ops" } },
      "datasource": { "type": "prometheus", "uid": "prometheus" }
    },
    {
      "id": 4,
      "title": "Kafka Listener Latency",
      "description": "Time spent processing messages in @KafkaListener methods",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "targets": [
        { "expr": "rate(spring_kafka_listener_seconds_sum[5m]) / rate(spring_kafka_listener_seconds_count[5m])", "legendFormat": "{{job}} avg", "refId": "A" },
        { "expr": "spring_kafka_listener_seconds_max", "legendFormat": "{{job}} max", "refId": "B" }
      ],
      "fieldConfig": { "defaults": { "unit": "s" } },
      "datasource": { "type": "prometheus", "uid": "prometheus" }
    }
  ],
  "schemaVersion": 39
}

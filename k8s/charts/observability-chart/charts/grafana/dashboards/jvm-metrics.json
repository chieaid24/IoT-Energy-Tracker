{
  "uid": "jvm-metrics",
  "title": "JVM Metrics",
  "tags": ["iot", "jvm"],
  "timezone": "browser",
  "refresh": "30s",
  "time": { "from": "now-1h", "to": "now" },
  "templating": {
    "list": [
      {
        "name": "service",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "query": "label_values(jvm_memory_used_bytes, job)",
        "refresh": 2,
        "includeAll": false,
        "current": { "text": "user-service", "value": "user-service" }
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "title": "Heap Used",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "targets": [{ "expr": "jvm_memory_used_bytes{area=\"heap\", job=\"$service\"}", "legendFormat": "{{id}}", "refId": "A" }],
      "fieldConfig": { "defaults": { "unit": "bytes" } },
      "datasource": { "type": "prometheus", "uid": "prometheus" }
    },
    {
      "id": 2,
      "title": "Heap Max",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "targets": [{ "expr": "jvm_memory_max_bytes{area=\"heap\", job=\"$service\"}", "legendFormat": "{{id}}", "refId": "A" }],
      "fieldConfig": { "defaults": { "unit": "bytes" } },
      "datasource": { "type": "prometheus", "uid": "prometheus" }
    },
    {
      "id": 3,
      "title": "GC Pause Rate",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 8 },
      "targets": [{ "expr": "rate(jvm_gc_pause_seconds_sum{job=\"$service\"}[5m])", "legendFormat": "{{action}} {{cause}}", "refId": "A" }],
      "fieldConfig": { "defaults": { "unit": "s" } },
      "datasource": { "type": "prometheus", "uid": "prometheus" }
    },
    {
      "id": 4,
      "title": "Live Threads",
      "type": "stat",
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 8 },
      "targets": [{ "expr": "jvm_threads_live_threads{job=\"$service\"}", "refId": "A" }],
      "fieldConfig": { "defaults": { "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }] } } },
      "options": { "colorMode": "value", "graphMode": "area", "textMode": "auto" },
      "datasource": { "type": "prometheus", "uid": "prometheus" }
    },
    {
      "id": 5,
      "title": "CPU Usage",
      "type": "gauge",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 8 },
      "targets": [{ "expr": "process_cpu_usage{job=\"$service\"}", "refId": "A" }],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 0.5 }, { "color": "red", "value": 0.8 }] }
        }
      },
      "datasource": { "type": "prometheus", "uid": "prometheus" }
    }
  ],
  "schemaVersion": 39
}

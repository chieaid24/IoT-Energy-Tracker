{
  "uid": "iot-business-metrics",
  "title": "IoT Business Metrics",
  "tags": ["iot", "business"],
  "timezone": "browser",
  "refresh": "30s",
  "time": { "from": "now-1h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "title": "Energy Events Ingested / min",
      "description": "Rate of energy usage events produced by ingestion-service",
      "type": "stat",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 0 },
      "targets": [{ "expr": "rate(spring_kafka_template_seconds_count{job=\"ingestion-service\"}[1m]) * 60", "refId": "A" }],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": { "mode": "absolute", "steps": [{ "color": "blue", "value": null }] }
        }
      },
      "options": { "colorMode": "value", "graphMode": "area", "textMode": "auto" },
      "datasource": { "type": "prometheus", "uid": "prometheus" }
    },
    {
      "id": 2,
      "title": "Insight API Max Latency",
      "description": "Max latency for insight-service HTTP requests (Spring AI + Ollama)",
      "type": "stat",
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 0 },
      "targets": [{ "expr": "http_server_requests_seconds_max{job=\"insight-service\"}", "refId": "A" }],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 1 }, { "color": "red", "value": 5 }] }
        }
      },
      "options": { "colorMode": "value", "graphMode": "none", "textMode": "auto" },
      "datasource": { "type": "prometheus", "uid": "prometheus" }
    },
    {
      "id": 3,
      "title": "Scheduled Task Executions (usage-service)",
      "description": "Rate of scheduled task executions in usage-service (threshold checks, etc.)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 0 },
      "targets": [{ "expr": "rate(tasks_scheduled_execution_seconds_count{job=\"usage-service\"}[5m])", "legendFormat": "executions/s", "refId": "A" }],
      "fieldConfig": { "defaults": { "unit": "ops" } },
      "datasource": { "type": "prometheus", "uid": "prometheus" }
    },
    {
      "id": 4,
      "title": "Alert Service — Kafka Listener Processing",
      "description": "Rate of alert events consumed and processed by alert-service",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "targets": [{ "expr": "rate(spring_kafka_listener_seconds_count{job=\"alert-service\"}[5m])", "legendFormat": "alerts processed/s", "refId": "A" }],
      "fieldConfig": { "defaults": { "unit": "ops" } },
      "datasource": { "type": "prometheus", "uid": "prometheus" }
    },
    {
      "id": 5,
      "title": "Usage Service — Records Consumed / min",
      "description": "Energy usage records consumed from Kafka per minute",
      "type": "stat",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "targets": [{ "expr": "rate(kafka_consumer_fetch_manager_records_consumed_total{job=\"usage-service\"}[1m]) * 60", "refId": "A" }],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": { "mode": "absolute", "steps": [{ "color": "blue", "value": null }] }
        }
      },
      "options": { "colorMode": "value", "graphMode": "area", "textMode": "auto" },
      "datasource": { "type": "prometheus", "uid": "prometheus" }
    }
  ],
  "schemaVersion": 39
}
